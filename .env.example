# Bank Portal Credentials
BANK_URL=https://your-bank-portal.kz
BANK_LOGIN=your_login
BANK_PASSWORD=your_password

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Формат: chatId или chatId:threadId (для тем)
# Примеры: -1001234567890 или -1001234567890:15
TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210:5
TELEGRAM_ADMIN_ID=admin_chat_id # Для критических ошибок и СМС

# Application Settings
CHECK_INTERVAL_MINUTES=1

# Render Cloud Settings (автоматически устанавливаются на Render)
# PORT=3000
# RENDER=true
# NODE_ENV=production
